{
  "name": "serverstat",
  "version": "1.0.0-alpha.1",
  "description": "Server monitoring dashboard — real-time CPU, GPU, RAM, Disk, Network & process stats",
  "type": "module",
  "bin": {
    "serverstat": "./app/dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
