{
  "name": "serverstat-monorepo",
  "version": "1.0.0-alpha.3",
  "private": true,
  "scripts": {
    "build:ui": "pnpm --filter serverstat-ui build",
    "build:cli": "pnpm --filter serverstat build",
    "build:all": "pnpm build:ui && pnpm build:cli",
    "dev:ui": "pnpm --filter serverstat-ui dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "quality": "pnpm lint && pnpm typecheck && pnpm format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3",
    "rimraf": "^6.1.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
